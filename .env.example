# =========================================================================
# 짜투(ZZATU) 환경 변수 — 예시 파일
# =========================================================================
# 이 파일은 placeholder 만 들어있는 공유용 템플릿입니다.
# 실제 값은 .env.local 에 넣으세요. (.env.local 은 git 에 올라가지 않습니다)
#
# 값을 얻는 곳: Supabase Dashboard → Project Settings → API
# =========================================================================

# ---------- 클라이언트(브라우저) + 서버 양쪽에서 사용 ----------
# Project URL — 예: https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Publishable Key — 새 방식 (sb_publishable_ 로 시작)
# 공개돼도 어느 정도 안전한 키 (RLS 가 막아주므로)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_여기에_키_붙여넣기


# ---------- 서버 사이드 전용 (절대 클라이언트 코드에 노출 금지!) ----------
# Service Role Key — RLS 우회 가능. 운영자 페이지에서만 사용.
# Phase 4(운영) 단계까지는 비워둬도 동작에 문제없음.
SUPABASE_SERVICE_ROLE_KEY=
