# ===========================================
# .gitignore — Git이 무시할 파일 목록
# ===========================================

# --- 비밀 정보 (절대 커밋 금지) ---
.env
.env.*
!.env.example
*.pem
*.key
secrets.json

# --- OS가 만드는 파일 ---
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride

# --- 에디터/IDE 설정 ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- 로그 / 임시 파일 ---
*.log
logs/
*.tmp
*.temp
*.bak

# ===========================================
# 아래는 기술 스택 정해지면 사용될 항목 (미리 포함)
# ===========================================

# --- Node.js (JavaScript/TypeScript 프로젝트용) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
dist/
build/
.next/
.nuxt/
.turbo/
.cache/
coverage/
*.tsbuildinfo

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- 데이터베이스 / 데이터 파일 ---
*.sqlite
*.sqlite3
*.db
